# Скопіюйте в .env на сервері (не комітити).
# Повний перелік див. config.py

# --- Адмінка (Flask) ---
# На VPS за nginx часто достатньо 127.0.0.1 у контейнері й проксі на хості.
MEDIAHUB_ADMIN_HOST=0.0.0.0
MEDIAHUB_ADMIN_PORT=8765
# MEDIAHUB_NO_ADMIN=1

# --- YouTube Live ---
# YOUTUBE_RTMP_URL=rtmp://a.rtmp.youtube.com/live2/XXXX
# або лише ключ:
# YOUTUBE_STREAM_KEY=

# --- X (Twitter) Live ---
# X_RTMP_URL=
# X_STREAM_KEY=
# X_INGEST_BASE=rtmps://fr.pscp.tv:443/x

# --- Бітрейт відео (за потреби) ---
# MEDIAHUB_VIDEO_BITRATE=4500k
# MEDIAHUB_VIDEO_MAXRATE=4500k
# MEDIAHUB_VIDEO_BUFSIZE=9000k

# --- Логотип ---
# MEDIAHUB_LOGO_OPACITY=0.5
# MEDIAHUB_LOGO_FIT_FRACTION=0.25
# MEDIAHUB_LOGO_ZOOM=1.0
